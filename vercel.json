{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "roadsos.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/roadsos.html",
      "dest": "/roadsos.html"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}